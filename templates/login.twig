{% extends "core.twig" %}
{% from "macros/common.twig" import card_begin %}
{% from "macros/common.twig" import card_end %}

{% block content %}
{{ card_begin("Log in to CustoDesk") }}
	<center>
		<form action="" method="post" id="loginForm">
			<table>
				<tbody>
					<tr>
						<td><label for="username">Username:</label></td>
						<td><input type="text" name="username" value="{{ data.username }}" required=""></td>
					</tr>
					<tr>
						<td><label for="password">Password:</label></td>
						<td><input type="password" name="password" required=""></td>
					</tr>
				</tbody>
			</table>
			<div class="checkbox">
				<input type="checkbox" name="remember" id="remember" {{ data.remember ? "checked" }}>
				<label for="remember">Remember me</label>
			</div>
			<input type="submit" value="Log in">
		</form>
		<p style="margin-bottom:4px">Don't have an account? <a href="/register">Create one!</a></p>
		<p style="margin-top:4px"><a href="/password_reset">Forgot your password?</a></p>
	</center>
{{ card_end() }}
{% endblock %}