{% extends "two_col_page.twig" %}
{% from "macros/common.twig" import card_begin, card_end, subnav, user %}

{% block left_col_content %}
{{ card_begin("You are logged in as") }}
    {{ user(data.user) }}
{{ card_end() }}
{{ card_begin("Admin Control Panel") }}
    {{ subnav([
        [ null, "Dashboard",   "dashboard",   "/admin" ],
        [ null, "Alerts",      "alerts",      "/admin/alerts" ],
        [ null, "Invite Keys", "invite_keys", "/admin/invite_keys" ],
    ]) }}
{{ card_end() }}
{% endblock %}