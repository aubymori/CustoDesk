        {{ rich_edit() }}
        <div class="formButtons right">
            <input type="submit" value="Submit">
        </div>
    </form>
    <br>
    <b>Result:</b>
    <br>
    {{ data.html|raw|keepspace }}
{{ card_end() }}
{% endblock %}